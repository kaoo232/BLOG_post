			/* ── HERO FRAME (base sizing; flashlight behavior added below for mouse devices) ── */
			.post-hero-frame.flashlight-frame {
				border: var(--border-thick);
				box-shadow: var(--shadow-lg);
				background: #000;
				margin: 2rem auto;
				display: table; 
				width: auto;
				max-width: 100%;
				position: relative;
				overflow: hidden;
			}

			.post-hero-img {
				display: block;
				width: 100%;
				height: auto;
				max-height: 80vh;
				object-fit: contain;
				filter: brightness(0.3) sepia(20%);
				transition: filter 0.3s ease;
			}

			/* ── FLASHLIGHT MECHANIC ──
			   Desktop: moving the mouse over the frame reveals the spot (the
			   .is-active class is added on pointerenter/pointermove by the script
			   below). Mobile/touch: press-and-drag a finger across the photo to
			   reveal the same spot, following the touch point — same effect, just
			   triggered by touch instead of hover, since touchscreens have no
			   hover concept. */
			.post-hero-frame.flashlight-frame.is-active .post-hero-img {
				filter: brightness(1) sepia(5%) contrast(1.15);
				mask-image: radial-gradient(
					circle 150px at var(--mouse-x, 50%) var(--mouse-y, 50%), 
					rgba(0,0,0,1) 20%, 
					rgba(0,0,0,0) 100%
				);
				-webkit-mask-image: radial-gradient(
					circle 150px at var(--mouse-x, 50%) var(--mouse-y, 50%), 
					rgba(0,0,0,1) 20%, 
					rgba(0,0,0,0) 100%
				);
			}

			.post-hero-frame.flashlight-frame {
				touch-action: none; /* dragging a finger reveals the photo instead of scrolling the page */
			}

			@media (hover: hover) and (pointer: fine) {
				.post-hero-frame.flashlight-frame {
					cursor: crosshair;
				}
			}

			/* ==========================================================================
			   RESPONSIVE BREAKPOINTS
			   ========================================================================== */
			@media (max-width: 640px) {
				.article-container {
					padding: 0 1rem 3.5rem;
				}

				body {
					font-size: 1.05rem;
				}

				.post-header {
					margin: 1.5rem 0 2rem 0;
				}

				.magazine-meta-row {
					gap: 0.5rem 0.6rem;
				}

				.comic-badge {
					font-size: 0.68rem;
				}

				.post-date {
					font-size: 0.72rem;
					white-space: normal;
				}

				.post-content blockquote {
					padding: 0.85rem 1.1rem;
					font-size: 1.15rem;
				}

				.post-footer-panel {
					flex-direction: column;
					align-items: flex-start;
					text-align: left;
					padding: 1.25rem;
				}

				.comic-end-stamp {
					align-self: flex-start;
					font-size: 1.4rem;
				}

				.wbnz-email-signup-form {
					padding: 1.25rem !important;
				}

				.wbnz-email-signup-form button {
