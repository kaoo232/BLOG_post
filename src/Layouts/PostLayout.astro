---
const { frontmatter } = Astro.props;
const url = Astro.url;
import Header from '../components/Static/Header.astro';

// Posts live as plain markdown pages in src/pages/blog/ (no content collection),
// so we pull them in with import.meta.glob rather than getCollection(). Each
// module exposes `frontmatter` (the post's frontmatter) and `url` (the final
// built page URL), which is exactly what we need to build prev/next links.
//
// NOTE: adjust the glob path below if this layout file lives somewhere other
// than src/layouts/ — it must resolve to src/pages/blog/*.md.
const postModules = import.meta.glob('../pages/blog/*.md', { eager: true });

const allPosts = Object.values(postModules).map((mod) => ({
  frontmatter: mod.frontmatter,
  url: mod.url,
}));

const sortedPosts = allPosts.sort((a, b) => {
  const dateA = new Date(a.frontmatter.pubDate).getTime();
  const dateB = new Date(b.frontmatter.pubDate).getTime();

  // If dates are invalid, treat them as 0, but log an error to find the culprit
  if (isNaN(dateA)) console.error(`Invalid date in: ${a.frontmatter.title}`);
  if (isNaN(dateB)) console.error(`Invalid date in: ${b.frontmatter.title}`);

  return dateA - dateB; // Ascending: Oldest to Newest
});


// 1. Ensure your helper handles trailing slashes consistently
const normalize = (path) => path?.replace(/\/+$/, "").toLowerCase() || "";

// 2. The finding logic
const currentPath = normalize(url?.pathname);

// Current index is the position of your current chapter
const currentIndex = sortedPosts.findIndex((p) => normalize(p.url) === currentPath);

console.log("All posts found:", allPosts.map(p => p.frontmatter.title));

// Previous is index - 1 (the one before)
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

// Next is index + 1 (the one after)
const nextPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
---


<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
