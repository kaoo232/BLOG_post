				}

				.post-content h2 {
					font-size: 1.5rem;
				}

				.post-content h3 {
					font-size: 1.2rem;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.post-hero-img,
				.wbnz-email-signup-form button {
					transition: none !important;
				}
			}
		</style>
	</head>
	
	<body>
		<div class="article-container">
			<Header />

			<!-- Progress Bar Elements -->
			<div id="phantom-progress-bar" style="
				position: fixed;
				top: 0;
				left: 0;
				width: 0%;
				height: 2px;
				background: var(--ink);
				z-index: 9999;
				transition: width 0.1s ease-out;
			"></div>

			<div id="phantom-progress-tracker" style="
				position: fixed;
				bottom: 20px;
				right: 20px;
				font-family: 'Special Elite', serif;
				font-size: 0.75rem;
				color: var(--ink);
				opacity: 0.6;
				letter-spacing: 0.1em;
				z-index: 9998;
				pointer-events: none;
			">
				LOG DEPTH: <span id="phantom-progress-percent">0%</span>
			</div>

			<script>
				document.addEventListener('DOMContentLoaded', function() {
					const progressBar = document.getElementById('phantom-progress-bar');
					const progressPercent = document.getElementById('phantom-progress-percent');
					
					function updateReadingProgress() {
						const scrollTop = window.scrollY || document.documentElement.scrollTop;
						const totalHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
						
						if (totalHeight > 0) {
							const percentage = Math.min(Math.floor((scrollTop / totalHeight) * 100), 100);
							if(progressBar) progressBar.style.width = percentage + '%';
							if(progressPercent) progressPercent.textContent = percentage + '%';
						} else {
							if(progressBar) progressBar.style.width = '0%';
							if(progressPercent) progressPercent.textContent = '0%';
						}
					}

					window.addEventListener('scroll', updateReadingProgress, { passive: true });
					window.addEventListener('resize', updateReadingProgress);
					updateReadingProgress();
				});
			</script>

			<article>
				<!-- Post Metadata Row -->
				<header class="post-header">
					<div class="magazine-meta-row">
						{frontmatter.issue && <span class="comic-badge issue">ISSUE #{frontmatter.issue}</span>}
						{frontmatter.category && <span class="comic-badge">{frontmatter.category}</span>}
						<span class="post-date">[{frontmatter.pubDate}] &nbsp;·&nbsp; Recorded by {frontmatter.author || 'The Resident'}</span>
					</div>
					<h1 class="post-title">{frontmatter.title}</h1>
				</header>

				<!-- Big Framed Hero Photo -->
				{frontmatter.heroImage && (
					<div class="post-hero-frame flashlight-frame" id="flashlight-hero">
						<img class="post-hero-img" src={frontmatter.heroImage} alt={frontmatter.title} />
					</div>
				)}

				<script>
					const flashlightHero = document.getElementById('flashlight-hero');
					if (flashlightHero) {
						function updateSpot(clientX, clientY) {
							const rect = flashlightHero.getBoundingClientRect();
							const x = ((clientX - rect.left) / rect.width) * 100;
							const y = ((clientY - rect.top) / rect.height) * 100;
							flashlightHero.style.setProperty('--mouse-x', `${x}%`);
							flashlightHero.style.setProperty('--mouse-y', `${y}%`);
						}

						// Mouse: reveal follows the cursor the whole time it's over the photo.
						flashlightHero.addEventListener('pointerenter', (e) => {
							if (e.pointerType === 'mouse') {
								updateSpot(e.clientX, e.clientY);
								flashlightHero.classList.add('is-active');
							}
						});

						flashlightHero.addEventListener('pointerleave', (e) => {
							if (e.pointerType === 'mouse') {
								flashlightHero.classList.remove('is-active');
							}
						});

						// Touch/pen: reveal follows the finger while it's pressed and dragging.
						flashlightHero.addEventListener('pointerdown', (e) => {
							if (e.pointerType !== 'mouse') {
								updateSpot(e.clientX, e.clientY);
								flashlightHero.classList.add('is-active');
							}
						});

						['pointerup', 'pointercancel'].forEach((eventName) => {
							flashlightHero.addEventListener(eventName, (e) => {
								if (e.pointerType !== 'mouse') {
									flashlightHero.classList.remove('is-active');
								}
							});
						});

						// Position updates for both input types while active.
						flashlightHero.addEventListener('pointermove', (e) => {
							updateSpot(e.clientX, e.clientY);
						});
					}
				</script>

				<!-- Rendered Markdown Content Blocks -->
				<main class="post-content">
					<slot />
				</main>

				<!-- Vintage Comic Sign-Off Footer Box -->
				<footer class="post-footer-panel">
					<div class="footer-panel-text">
						<h4>End of Record</h4>
						<p>The phantoms retreat to the corridors. A new window lights up next week.</p>
					</div>
					<div class="comic-end-stamp">TO BE CONTINUED...</div>
				</footer>

				<!-- THEMATIC INTERACTION ZONE -->
				
				<!-- THEMATIC INTERACTION ZONE -->
<section class="interaction-zone">
    <div style="display: flex; justify-content: center;">
        <div class='wbnz-email-signup-form' data-webynize-id='11228'></div>
        <!-- Using is:inline ensures the script loads as-is -->
        <script is:inline defer src='https://widgets.webynize.com/email-signup-form.js'></script>
    </div>

    <div style="
        max-height: 480px;
        overflow-y: auto;
        overflow-x: hidden;
        border: var(--border);
        box-shadow: var(--shadow);
    ">
        <script is:inline src="https://cdn.commoninja.com/sdk/latest/commonninja.js" defer></script>
        <div class="commonninja_component pid-8f00ac37-abcc-45a3-a972-e4474801aaf6"></div>
    </div>
</section>
			</article>

			<hr class="separator"/>

			<!-- 2.The next / Previous Navigation-->
			<div class="navigation-container">
  <!-- Previous Button: Shows if there is a previous post -->
  {prevPost ? (
    <a href={prevPost.url} class="nav-btn prev">
      ← Previous: {prevPost.frontmatter.title}
    </a>
  ) : (
    <span class="nav-placeholder" /> 
  )}

  <!-- Next Button: Only renders if a next post exists -->
  {nextPost && (
    <a href={nextPost.url} class="nav-btn next">
      Next: {nextPost.frontmatter.title} →
    </a>
  )}
</div>

			<!-- 3.Component Styles -->

			<style> 
			
