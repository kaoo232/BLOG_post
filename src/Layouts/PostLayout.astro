		<style is:global>
			:root {
				/* Muted, mysterious, vintage paper tones (Light Mode) */
				--ink: #111612; /* Deep, near-black ink */
				--paper: #eaddca; /* Aged, antique book page color */
				--paper-dark: #d2c1ae;
				--cream: #f4efe6;
				--red: #32746D; /* Crimson/Burgundy instead of bright red */
				--yellow: #c2a649; /* Antique gold instead of bright yellow */
				--teal: #2a443b; /* Deep forest/phantom green */
				--teal-light: #416659;
				--panel-bg: #ebdcb9;

				--border: 3px solid var(--ink);
				--border-thick: 4px solid var(--ink);
				--shadow: 5px 5px 0px var(--ink);
				--shadow-lg: 7px 7px 0px var(--ink);
			}

			body.dark {
				/* Perfect inverted alignment (Dark Archive Mode) */
				--ink: #f4efe6; /* Text flips to clean cream color */
				--paper: #111612; /* Background flips to deep near-black ink */
				--paper-dark: #1a231d;
				--cream: #1c241f; 
				--panel-bg: #18211b; 
				
				--red: #4da39a; /* Inverted accent to pop beautifully on dark backgrounds */
				--yellow: #dfc365; 
				--teal: #416659; 
				--teal-light: #568575;

				--border: 3px solid var(--ink);
				--border-thick: 4px solid var(--ink);
				--shadow: 5px 5px 0px var(--ink);
				--shadow-lg: 7px 7px 0px var(--ink);
			}

			*, *::before, *::after { 
				box-sizing: border-box; 
				margin: 0; 
				padding: 0; 
			}

			html {
				-webkit-text-size-adjust: 100%;
				text-size-adjust: 100%;
			}

			body {
				background-color: var(--paper);
				color: var(--ink);
				font-family: 'IM Fell DW Pica', serif; /* Immersive, literary serif body text */
				font-size: 1.15rem;
				line-height: 1.65;
				min-height: 100vh;
				overflow-x: hidden;
				transition: background-color 0.4s ease, color 0.4s ease;
				
